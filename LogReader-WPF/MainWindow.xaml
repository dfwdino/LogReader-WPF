<Window x:Class="LogReader_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LogReader_WPF"
        mc:Ignorable="d"
        Title="Log Reader" Height="900" Width="1600"
        MinWidth="800" MinHeight="500"
        Loaded="Window_Loaded" Closed="Window_Closed" KeyDown="Window_KeyDown"
        Background="#F5F5F5">
    <Window.Resources>
        <!-- Modern button style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0D47A1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- DataGrid styles -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E0E0E0"/>
        </Style>

        <!-- Dropdown submenu items: force dark text so they're readable on white popup background -->
        <Style x:Key="SubMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#212121"/>
        </Style>

        <!-- Top-level menu item on the blue bar.
             Custom template removes the default icon column and centers text vertically.
             Darkens background on hover/open so white text stays readable. -->
        <Style x:Key="HeaderMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                Padding="12,0" VerticalAlignment="Stretch">
                            <Grid>
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"/>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                                    <Border Background="White" BorderBrush="#BDBDBD" BorderThickness="1" Padding="0,2">
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu bar -->
            <RowDefinition Height="Auto"/>
            <!-- Command bar -->
            <RowDefinition Height="*"/>
            <!-- Main content area -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Menu bar -->
        <Border Grid.Row="0" Background="#2196F3" BorderThickness="0,0,0,1" BorderBrush="#1976D2">
            <Menu Height="28" Name="menu1" Background="Transparent" Foreground="White" FontWeight="Medium" Padding="5,0">
                <MenuItem Name="MenuHistory" Header="_History" Style="{StaticResource HeaderMenuItem}">
                    <Separator/>
                    <MenuItem Header="Clear History" Tag="ClearHistory" Click="ClearHistory_Click" Style="{StaticResource SubMenuItem}"/>
                </MenuItem>
                <MenuItem Header="_Help" Style="{StaticResource HeaderMenuItem}">
                    <MenuItem Header="_About" Click="OpenAbout" Style="{StaticResource SubMenuItem}"/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- Command bar -->
        <Grid Grid.Row="1" Margin="15,15,15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto" MinWidth="316"/>
                <ColumnDefinition Width="Auto" MinWidth="95"/>
            </Grid.ColumnDefinitions>

            <!-- File controls group -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBox Name="LogFileLocation" Style="{StaticResource ModernTextBox}" Width="450" Margin="0,0,10,0"
                         IsReadOnly="True" Cursor="Arrow" ToolTip="Path of the currently loaded log file"/>
                <Button Content="Open Log" Style="{StaticResource ModernButton}" Click="OpenLogFile_Click" Width="66"
                        ToolTip="Open a log file (Ctrl+O)"/>
            </StackPanel>

            <!-- Statistics group -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                <Border Background="#FFEBEE" CornerRadius="3" Padding="8,5" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Rows:" Foreground="#D32F2F" FontWeight="SemiBold" Padding="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Name="RowCount" Text="0" Foreground="#D32F2F" FontWeight="Bold" VerticalAlignment="Center"
                                   ToolTip="Visible rows / total rows (filtered / total when a search is active)"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFEBEE" CornerRadius="3" Padding="8,5" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Errors:" Tag="Error" Foreground="#D32F2F" FontWeight="SemiBold" Padding="0,0,3,0"
                               VerticalAlignment="Center" MouseDoubleClick="ErrorLabel_MouseDoubleClick"
                               Cursor="Hand" ToolTip="Double-click to filter for errors"/>
                        <TextBlock Name="ErrorNumber" Text="0" Foreground="#D32F2F" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFFDE7" CornerRadius="3" Padding="8,5" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Warnings:" Tag="Warning" Foreground="#FFA000" FontWeight="SemiBold" Padding="0,0,3,0"
                               VerticalAlignment="Center" MouseDoubleClick="WarningLabel_MouseDoubleClick"
                               Cursor="Hand" ToolTip="Double-click to filter for warnings"/>
                        <TextBlock Name="WarningNumber" Text="0" Foreground="#FFA000" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Search group -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0">
                <TextBox Name="SearchBox" Style="{StaticResource ModernTextBox}" Width="200" Margin="0,0,10,0"
                         KeyDown="SearchBox_KeyDown" ToolTip="Search log content (Enter to search, Escape to clear)"/>
                <Button Content="Search" Style="{StaticResource ModernButton}" Click="SearchGrid" Margin="0,0,5,0" Width="55"
                        ToolTip="Search (Ctrl+F to focus)"/>
                <Button Content="Clear" Style="{StaticResource ModernButton}" Click="ClearSearch" Width="45"/>
            </StackPanel>

            <!-- View options -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="20,0,0,0">
                <Button Name="ShowHideFileList" Content="Hide File List" Style="{StaticResource ModernButton}" Click="HideShowFolderList" Width="85"/>
            </StackPanel>
        </Grid>

        <!-- Main content area with file list and log display -->
        <Grid x:Name="FileListGrid" Grid.Row="2" Margin="15,0,15,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="250" MaxWidth="350"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- File list panel -->
            <Border x:Name="FileListPanel" Grid.Column="0" BorderThickness="1" BorderBrush="#E0E0E0" Background="White" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Log Files" Grid.Row="0" Margin="10,10,10,5" FontWeight="SemiBold" Foreground="#424242"/>

                    <ListBox Grid.Row="1" Name="FileList" Margin="10,0,10,10" BorderThickness="0"
                             SelectionChanged="LoadLogFile"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="NoWrap" Margin="0,5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter x:Name="FileListSplitter" Grid.Column="1" Width="8" HorizontalAlignment="Center"
                          Background="Transparent" Margin="2,0"
                          Template="{DynamicResource ModernGridSplitter}">
                <GridSplitter.Resources>
                    <ControlTemplate x:Key="ModernGridSplitter" TargetType="{x:Type GridSplitter}">
                        <Border Background="Transparent" Padding="3,0">
                            <Rectangle Width="2" Fill="#BDBDBD" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Resources>
            </GridSplitter>

            <!-- Log content area -->
            <Border Grid.Column="2" BorderThickness="1" BorderBrush="#E0E0E0" Background="White" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Log Content" Grid.Row="0" Margin="10,10,10,5" FontWeight="SemiBold" Foreground="#424242"/>

                    <DataGrid Grid.Row="1"
                              Margin="10,0,10,10"
                              x:Name="LogFileData"
                              Style="{StaticResource ModernDataGrid}"
                              AllowDrop="True"
                              Drop="DataGridFile_Drop"
                              AutoGenerateColumns="False"
                              GridLinesVisibility="Horizontal"
                              CanUserAddRows="False"
                              HeadersVisibility="None"
                              BorderThickness="0">

                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy Row" Click="CopyRowContent_Click"/>
                                <Separator/>
                                <MenuItem Header="Copy All Visible Rows" Click="CopyAllContent_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Content" Binding="{Binding Content}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="5"/>
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Padding" Value="0,5"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                        <Setter Property="Background" Value="LightPink"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                        <Setter Property="Background" Value="#FFFDE7"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#EEEEEE" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <StatusBar Name="sbar" Height="26" VerticalAlignment="Stretch" Background="Transparent">
                <StatusBarItem>
                    <TextBlock Name="StatusBar" Margin="10,0" Foreground="#616161"/>
                </StatusBarItem>
            </StatusBar>
        </Border>
    </Grid>
</Window>
